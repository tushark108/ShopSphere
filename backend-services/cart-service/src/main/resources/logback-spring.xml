<configuration>

    <!-- External path -->
    <property name="LOG_PATH" value="C:/logs/cart-service"/>

    <!-- 1️⃣ Console Appender -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{HH:mm:ss} %-5level %logger - %msg%n</pattern>
        </encoder>
    </appender>

    <!-- 2️⃣ File Appender (ONLY timestamp files) -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        
        <rollingPolicy class="ch.qos.logback.core.rolling.TimeBasedRollingPolicy">

            <!-- ✅ Date + Time in filename -->
            <fileNamePattern>
                ${LOG_PATH}/cart-service-%d{yyyy-MM-dd_HH-mm}.log
            </fileNamePattern>

            <!-- Keep last 7 days -->
            <maxHistory>7</maxHistory>

        </rollingPolicy>

        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss} %-5level %logger - %msg%n</pattern>
        </encoder>

    </appender>

    <!-- 3️⃣ Both console + file -->
    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </root>

</configuration>